DATABASE_URL=postgres://lothal:lothal@localhost:5433/lothal_util

# MQTT broker (for Emporia Vue / Home Assistant integration)
MQTT_BROKER=mqtt://localhost:1883
MQTT_TOPICS=homeassistant/sensor/emporia_vue/#

# NWS weather station (KGOK = Guthrie-Edmond Regional Airport)
NWS_STATION=KGOK

# Flume water meter API (optional)
FLUME_CLIENT_ID=
FLUME_CLIENT_SECRET=
FLUME_USERNAME=
FLUME_PASSWORD=

# Ecobee thermostat API (optional)
ECOBEE_API_KEY=
