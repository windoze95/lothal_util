DATABASE_URL=postgres://lothal:lothal@localhost:5433/lothal_util

# MQTT broker (for Emporia Vue / Home Assistant integration)
MQTT_BROKER=mqtt://localhost:1883
MQTT_TOPICS=homeassistant/sensor/emporia_vue/#

# NWS weather station (KGOK = Guthrie-Edmond Regional Airport)
NWS_STATION=KGOK

# Flume water meter API (optional)
FLUME_CLIENT_ID=
FLUME_CLIENT_SECRET=
FLUME_USERNAME=
FLUME_PASSWORD=

# Ecobee thermostat API (optional)
ECOBEE_API_KEY=

# -----------------------------------------------------------------------------
# LLM provider — used for briefings, bill parsing, and diagnose mode
# -----------------------------------------------------------------------------
LOTHAL_LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-6
# For Ollama instead, set LOTHAL_LLM_PROVIDER=ollama and:
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=gemma4:31b

# -----------------------------------------------------------------------------
# Briefing + anomaly alert delivery target
# One of: stdout, ha (Home Assistant notify), slack (webhook)
# -----------------------------------------------------------------------------
BRIEFING_OUTPUT=stdout
# HA_BASE_URL=http://homeassistant.local:8123
# HA_TOKEN=
# SLACK_WEBHOOK_URL=

# -----------------------------------------------------------------------------
# IMAP email ingest (used by the scheduler daemon to auto-import utility bills)
# -----------------------------------------------------------------------------
# IMAP_SERVER=imap.fastmail.com
# IMAP_PORT=993
# IMAP_USER=
# IMAP_PASSWORD=
# IMAP_FOLDER=INBOX
# IMAP_PROCESSED_FOLDER=Lothal/Processed
# IMAP_SENDER_PATTERNS=oge,ong,guthrie,oklahoma gas,oklahoma natural
